{
  "name": "v-mapkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geoql/v-mapkit.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @geoql/v-mapkit run build && pnpm --filter mapkit-cn-app run build && pnpm --filter v-mapkit-docs run build",
    "build:app": "pnpm --filter mapkit-cn-app run build",
    "build:docs": "pnpm --filter v-mapkit-docs run build",
    "dev:app": "pnpm --filter mapkit-cn-app run dev",
    "dev:docs": "pnpm --filter v-mapkit-docs run dev",
    "dev:lib": "pnpm --filter @geoql/v-mapkit run dev",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "test": "pnpm --filter @geoql/v-mapkit run test",
    "test:coverage": "pnpm --filter @geoql/v-mapkit run test:coverage",
    "prepare": "is-ci || husky",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/.nuxt apps/*/.output",
    "update:deps": "pnpm dlx taze -I -r",
    "doctor:check": "vue-doctor"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:default",
    "@commitlint/config-conventional": "catalog:default",
    "husky": "catalog:default",
    "is-ci": "catalog:default",
    "lint-staged": "catalog:default"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
