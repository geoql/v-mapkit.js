{
  "name": "@geoql/v-mapkit.js",
  "version": "0.3.0",
  "private": false,
  "description": "MapKit with the power of Vue 3",
  "keywords": [
    "Apple MapKit",
    "Map Library",
    "MapKit",
    "Maps",
    "Vue MapKit",
    "v-mapkit.js",
    "vue-mapkit.js"
  ],
  "homepage": "https://github.com/geoql/v-mapkit.js#readme",
  "bugs": {
    "url": "https://github.com/geoql/v-mapkit.js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoql/v-mapkit.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/v-mapkit.js",
  "module": "./dist/v-mapkit.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/v-mapkit.mjs",
  "jsdelivr": "./dist/v-mapkit.mjs",
  "umd": "./dist/v-mapkit.umd.js",
  "exports": {
    ".": {
      "import": "./dist/v-mapkit.js",
      "require": "./dist/v-mapkit.umd.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly && prettier --write dist/*{mjs,js,ts}",
    "test": "echo 'test!'",
    "prepare": "husky",
    "lint": "oxlint && oxfmt --check",
    "lintfix": "oxlint --fix && oxfmt",
    "lint:oxlint": "oxlint",
    "lint:oxlint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint:css": "stylelint \"src/**/*.{css,scss,vue}\"",
    "lint:css:fix": "stylelint --fix \"src/**/*.{css,scss,vue}\"",
    "release": "shipjs prepare",
    "release:dry": "shipjs prepare --dry-run",
    "release:auto": "shipjs prepare --yes"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/apple-mapkit-js-browser": "^5.78.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/runtime-dom": "^3.5.0",
    "@vue/tsconfig": "^0.7.0",
    "@vueuse/core": "^14.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "postcss-html": "^1.8.1",
    "sass": "^1.83.0",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.0.0",
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "cdn": "./dist/v-mapkit.min.js"
}
