{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "sortImports": { "enabled": true },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "docs/.vitepress/cache/**"
  ]
}
