{
  "name": "@geoql/v-mapkit.js",
  "version": "0.3.0",
  "private": false,
  "description": "MapKit with the power of Vue 3",
  "keywords": [
    "Apple MapKit",
    "Map Library",
    "MapKit",
    "Maps",
    "Vue MapKit",
    "v-mapkit.js",
    "vue-mapkit.js"
  ],
  "homepage": "https://github.com/geoql/v-mapkit.js#readme",
  "bugs": {
    "url": "https://github.com/geoql/v-mapkit.js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geoql/v-mapkit.js.git",
    "directory": "packages/v-mapkit.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "vp pack",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint:css": "stylelint \"src/**/*.{css,scss,vue}\"",
    "lint:css:fix": "stylelint --fix \"src/**/*.{css,scss,vue}\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "bump-version": "node scripts/bump-jsr-version.mjs"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.2",
    "@types/apple-mapkit-js-browser": "^5.78.0",
    "@types/node": "^25.9.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/runtime-dom": "^3.5.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "happy-dom": "^17.6.3",
    "postcss-html": "^1.8.1",
    "sass": "^1.99.0",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript": "^6.0.3",
    "unplugin-vue": "^7.2.0",
    "vite-plus": "^0.1.24",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6",
    "vue": "^3.5.34",
    "vue-tsc": "^3.3.0"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.0.0",
    "vue": "^3.5.0"
  }
}
